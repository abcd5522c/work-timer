<?xml version='1.0' encoding='utf-8'?>
<widget id="com.workshift.app" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>WorkShift</name>
    <description>排班工時追蹤應用程式</description>
    <author email="support@workshift.app" href="https://worktimer-4bphxfae.manus.space">WorkShift Team</author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    <platform name="android">
        <allow-intent href="market:*" />
    </platform>
    <engine name="android" spec="^14.0.0" />
</widget>
